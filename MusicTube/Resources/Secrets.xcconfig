// Checked-in template config.
// Put your real values in Secrets.local.xcconfig, which is ignored by git.
// Native iOS OAuth uses PKCE here, so a client secret is not required.
YOUTUBE_API_KEY = YOUR_YOUTUBE_API_KEY
YOUTUBE_CLIENT_ID = YOUR_IOS_OAUTH_CLIENT_ID.apps.googleusercontent.com
YOUTUBE_URL_SCHEME = com.googleusercontent.apps.YOUR_IOS_CLIENT_ID
YOUTUBE_REDIRECT_URI = com.googleusercontent.apps.YOUR_IOS_CLIENT_ID:/oauth2redirect

#include? "Secrets.local.xcconfig"
